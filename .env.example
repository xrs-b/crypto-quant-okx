# -----------------------------------------------------------------------------
# crypto-quant-okx 环境变量示例
# 用法：cp .env.example .env 然后按需修改；生产环境请改成你自己的真实值
# -----------------------------------------------------------------------------

# 项目根目录（可选；脚本/cron/守护场景很有用）
PROJECT_DIR=/path/to/crypto-quant-okx

# OKX API（建议先用 testnet）
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_API_PASSPHRASE=your_okx_api_passphrase

# Dashboard
# 公开部署前请务必改成高强度随机字符串，例如：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SECRET_KEY=replace_with_a_long_random_secret
DASHBOARD_PORT=5555

# Discord（按需）
DISCORD_CHANNEL_ID=your_discord_channel_id
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# Telegram（按需）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email / SMTP（按需）
SMTP_PASSWORD=your_smtp_app_password
