# ============================================================================
# 本地私密配置示例（不要提交到 GitHub）
# ----------------------------------------------------------------------------
# 用法：cp config/config.local.yaml.example config/config.local.yaml
# 这里只放真实 secret / 私有 channel / 私有 webhook 等内容。
# presets 不应承载 notification secret；需要覆盖时统一写在这里或 .env。
# Config 会在读取 config.yaml 后，再自动合并本文件覆盖。
# 这是当前唯一默认推荐的本地私密配置来源。
# ~/.crypto-quant-okx.local.yaml 不再默认自动加载；仅兼容显式启用场景。
# ============================================================================

api:
  key: your_real_okx_api_key
  secret: your_real_okx_api_secret
  passphrase: your_real_okx_api_passphrase

notification:
  discord:
    channel_id: your_real_discord_channel_id
    webhook_url: https://discord.com/api/webhooks/xxx/yyy
    bot_token: your_real_discord_bot_token
  telegram:
    bot_token: your_real_telegram_bot_token
    chat_id: your_real_telegram_chat_id

trading:
  layering:
    layer_count: 3
    layer_ratios: [0.06, 0.06, 0.04]
    layer_max_total_ratio: 0.16
    min_add_interval_seconds: 300
    profit_only_add: false
    disallow_skip_layers: true
    signal_idempotency_enabled: true
    signal_idempotency_ttl_seconds: 600
    direction_lock_enabled: true
    direction_lock_scope: symbol
    direction_lock_release_on_flat: true
    require_position_exists: true
    allow_same_bar_multiple_adds: false
    max_layers_per_signal: 1
    strict_ratio_sum_check: false

