# =============================================================================
# OKX 量化交易机器人配置文件
# =============================================================================
# 使用说明：
# 1. 复制此文件为 config.yaml
# 2. 填入你的API密钥
# 3. 根据需要修改交易参数
# =============================================================================

# -----------------------------------------------------------------------------
# 交易所配置
# -----------------------------------------------------------------------------
exchange: okx                     # 交易所名称 (okx / binance / huobi 等)

# 交易模式: testnet (模拟交易) / real (真实交易)
# 注意：切换到real之前请确保API密钥是真实账户的
mode: testnet

# -----------------------------------------------------------------------------
# API密钥配置
# -----------------------------------------------------------------------------
# 获取方式：登录OKX → API管理 → 创建API
# 注意：必须开启 "合约交易" 权限
api:
  key: "你的API Key"              # API Key (如: 2588d12c-9301-40af-8f9a-xxx)
  secret: "你的Secret"            # Secret (如: CD65DC2B0F211F6EF7xxx)
  passphrase: "你的Passphrase"    # API Passphrase (创建API时设置的密码)

# -----------------------------------------------------------------------------
# 交易参数
# -----------------------------------------------------------------------------
trading:
  # 交易对列表 (支持的币种)
  symbols:
    - SOL/USDT                    # Solana
    - HYPE/USDT                   # Hyperliquid

  # 单笔仓位比例 (0.1 = 10% 账户余额)
  # 例如：账户10000USDT，单笔10% = 1000USDT
  position_size: 0.1

  # 最大仓位比例 (0.3 = 30% 账户余额)
  # 同时持仓多个币种时，总仓位不超过此比例
  max_exposure: 0.3

  # 杠杆倍数 (1-50倍，OKX合约最高支持50x)
  # 注意：杠杆越高，风险越大
  # 推荐：新手建议使用1-3倍
  leverage: 3

  # 止损比例 (0.02 = 2%)
  # 当亏损达到此比例时自动平仓 (已计算杠杆)
  # 例如：2%亏损 × 3倍杠杆 = 实际亏损6%
  stop_loss: 0.02

  # 止盈比例 (0.04 = 4%)
  # 当盈利达到此比例时自动平仓 (已计算杠杆)
  # 例如：4%盈利 × 3倍杠杆 = 实际盈利12%
  take_profit: 0.04

  # 追踪止损比例 (0.02 = 2%)
  # 价格朝有利方向移动后，回调此比例自动平仓
  # 用于锁定利润
  trailing_stop: 0.02

# -----------------------------------------------------------------------------
# 策略参数
# -----------------------------------------------------------------------------
strategy:
  # RSI 相对强弱指标参数
  rsi_period: 14                  # RSI周期 (默认14)

  # RSI 超卖阈值 (低于此值可能买入)
  # 数值越低越保守
  rsi_oversold: 35

  # RSI 超买阈值 (高于此值可能卖出)
  # 数值越高越保守
  rsi_overbought: 65

  # MACD 指数平滑异同移动平均线参数
  macd_fast: 12                   # 快线周期
  macd_slow: 26                   # 慢线周期
  macd_signal: 9                   # 信号线周期

# -----------------------------------------------------------------------------
# Discord 通知配置
# -----------------------------------------------------------------------------
discord:
  # 是否启用Discord通知
  enabled: true

  # Discord频道ID
  # 获取方式：在Discord开启开发者模式 → 右键频道 → 复制频道ID
  channel_id: "你的Discord Channel ID"

# =============================================================================
# 风险提示
# =============================================================================
# ⚠️ 合约交易风险极高，可能亏损全部资金！
# ⚠️ 请先用模拟盘(testnet)充分测试
# ⚠️ 请设置合理的止损止盈比例
# ⚠️ 不要投入超过承受能力的资金
# =============================================================================
