# ============================================================================
# OKX Quant 示例配置（可公开提交）
# ----------------------------------------------------------------------------
# 用法建议：
# 1. 先复制：cp config/config.yaml.example config/config.yaml
# 2. 再复制：cp config/config.local.yaml.example config/config.local.yaml
# 3. 把真实 secret 只写进 config.local.yaml，或者改用环境变量
# 4. config.yaml / config.local.yaml 都不会上传到 GitHub
#
# 环境变量写法示例：
#   key: ${OKX_API_KEY}
#   bot_token: ${DISCORD_BOT_TOKEN:-}
# ============================================================================

api:
  # OKX API（建议放到 config.local.yaml 或环境变量）
  key: ${OKX_API_KEY:-your_okx_api_key}
  passphrase: ${OKX_API_PASSPHRASE:-your_okx_api_passphrase}
  secret: ${OKX_API_SECRET:-your_okx_api_secret}

dashboard:
  auto_refresh_seconds: 30
  enabled: true
  host: 0.0.0.0
  port: 8050
  theme: dark
  title: OKX量化交易仪表盘

database:
  path: data/trading.db
  retention:
    logs_days: 30
    signals_days: 90
    trades_days: 365
  type: sqlite

exchange:
  default_leverage: 10
  mode: testnet         # testnet=模拟盘 / real=真实盘
  name: okx
  position_mode: hedge  # hedge=双向持仓 / oneway=单向持仓；必须与 OKX 账户设置一致

governance:
  pool_switch:
    min_hold_hours: 6
    score_margin: 1.0

logging:
  backup_count: 5
  file: logs/trading.log
  format: '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
  level: INFO
  max_size_mb: 10

market_filters:
  block_counter_trend: true
  block_high_volatility: true
  block_low_volatility: true
  max_volatility: 0.05
  min_volatility: 0.0045

ml:
  enabled: true
  features:
    - RSI
    - MACD
    - MACD_signal
    - MACD_hist
    - BB_upper
    - BB_lower
    - BB_position
    - MA5_ratio
    - trend_gap
    - volume_ratio
    - returns
    - returns_3d
    - returns_5d
    - volatility
    - momentum
    - atr_ratio
  min_confidence: 0.6
  model_path: ml/models
  training:
    label_horizon: 3
    min_return_threshold: 0.002

notification:
  discord:
    # 建议：channel_id / webhook / bot token 只放 config.local.yaml 或环境变量
    channel_id: ${DISCORD_CHANNEL_ID:-your_discord_channel_id}
    webhook_url: ${DISCORD_WEBHOOK_URL:-}
    webhook_username: OKX量化机器人
    bot_token: ${DISCORD_BOT_TOKEN:-}
    enabled: true
    notify_errors: true
    notify_signals: true
    notify_trades: true
  email:
    enabled: false
    password: ${SMTP_PASSWORD:-your_app_password}
    smtp_host: smtp.gmail.com
    smtp_port: 587
    to_address: your_email@gmail.com
    username: your_email@gmail.com
  telegram:
    bot_token: ${TELEGRAM_BOT_TOKEN:-}
    chat_id: ${TELEGRAM_CHAT_ID:-}
    enabled: false

runtime:
  interval_seconds: 300
  max_runtime_minutes: 30
  mode: interval
  schedule: 0 * * * *
  health_summary:
    enabled: true
    hour: 20   # 每日几时发一份健康汇总（24 小时制）

runtime_meta:
  current_preset: btc-focused

strategies:
  adx:
    enabled: true
    period: 14
    strength_weight: 20
    threshold: 25
  bollinger:
    enabled: true
    period: 20
    std_multiplier: 2
    strength_weight: 15
  composite:
    enabled: true
    min_strategy_count: 1
    min_strength: 28
  divergence:
    enabled: true
    lookback: 20
    strength_weight: 30
  ma_cross:
    enabled: true
    fast_period: 5
    slow_period: 20
    strength_weight: 25
  macd:
    enabled: true
    fast_period: 12
    signal_period: 9
    slow_period: 26
    strength_weight: 24
  pattern:
    enabled: true
    strength_weight: 20
  rsi:
    enabled: true
    overbought: 65
    oversold: 35
    period: 14
    strength_weight: 40
  volume:
    enabled: true
    strength_weight: 32
    volume_ma_period: 20
    volume_multiplier: 1.5

symbols:
  candidate_watch_list:
    - BTC/USDT
  contract_type: usdt
  margin_type: isolated
  paused_watch_list:
    - ETH/USDT
    - SOL/USDT
    - HYPE/USDT
  quote_currency: USDT
  selection_mode: focused
  watch_list:
    - XRP/USDT

# 按币种局部覆盖：只改你想灰度测试既参数，未写既项会继续沿用全局默认值
symbol_overrides:
  BTC/USDT:
    strategies:
      composite:
        min_strategy_count: 2
    market_filters:
      block_counter_trend: true
  XRP/USDT:
    strategies:
      composite:
        min_strength: 26
    market_filters:
      min_volatility: 0.0038

trading:
  cooldown_minutes: 15
  leverage: 10
  max_consecutive_losses: 3
  loss_streak_lock_enabled: true
  loss_streak_cooldown_hours: 12
  max_daily_drawdown: 0.03
  max_exposure: 0.3
  max_position_per_symbol: 0.15
  max_trades_per_day: 10
  min_trade_interval: 300
  position_size: 0.1
  stop_loss: 0.018
  take_profit: 0.028
  trailing_stop: 0.01
  # 盈利触发型追踪止损：盈利达到此阈值后激活追踪（0.01 = 1%）
  # 设置为 null 或删除则始终激活（旧行为）
  trailing_activation: 0.01
  # 分批止盈 / 部分平仓机制（第一止盈层）
  # 启用分批止盈
  # partial_tp_enabled: false
  # 部分止盈触发阈值（杠杆后盈利达到此比例时执行第一次部分平仓）
  # 例如 0.015 = 1.5% 盈利（10x杠杆对应 15% 涨幅）
  # partial_tp_threshold: 0.015
  # 部分平仓比例（每次平仓的仓位占比）
  # 例如 0.5 = 每次平 50% 仓位
  # partial_tp_ratio: 0.5
