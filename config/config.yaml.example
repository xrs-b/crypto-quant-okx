# =============================================================================
# OKX量化交易系统配置文件
# =============================================================================
# 使用说明：
# 1. 复制此文件为 config.yaml
# 2. 填入你的API密钥
# 3. 根据需要修改交易参数
# =============================================================================

# -----------------------------------------------------------------------------
# 交易所配置
# -----------------------------------------------------------------------------
exchange:
  name: okx                     # 交易所名称
  mode: testnet               # testnet (模拟) / real (真实)
  default_type: swap          # swap (永续) / futures (期货)

# -----------------------------------------------------------------------------
# API密钥配置 (必须)
# -----------------------------------------------------------------------------
# 获取方式：登录OKX → API管理 → 创建API
# 注意：必须开启 "合约交易" 权限
api:
  key: "your_api_key"        # API Key
  secret: "your_secret"      # Secret
  passphrase: "your_passphrase"  # Passphrase

# -----------------------------------------------------------------------------
# 交易对配置
# -----------------------------------------------------------------------------
symbols:
  # 交易对列表
  list:
    - BTC/USDT
    - ETH/USDT
    - SOL/USDT
    - XRP/USDT
    - HYPE/USDT

  # 每个币种独立配置
  configs:
    BTC:
      enabled: true
      weight: 0.3        # 仓位权重
    ETH:
      enabled: true
      weight: 0.3
    SOL:
      enabled: true
      weight: 0.2
    XRP:
      enabled: true
      weight: 0.1
    HYPE:
      enabled: true
      weight: 0.1

# -----------------------------------------------------------------------------
# 仓位管理
# -----------------------------------------------------------------------------
position:
  total_limit: 0.3           # 总仓位上限 (30%)
  single_limit: 0.1         # 单笔仓位上限 (10%)
  leverage: 10               # 杠杆倍数 (1-50)
  min_balance: 1000         # 最小保留余额

# -----------------------------------------------------------------------------
# 风险管理
# -----------------------------------------------------------------------------
risk:
  stop_loss: 0.02           # 止损比例 (2%)
  take_profit: 0.04         # 止盈比例 (4%)
  trailing_stop: 0.02       # 追踪止损 (2%)
  max_daily_loss: 0.10      # 单日最大亏损 (10%)

# -----------------------------------------------------------------------------
# 策略配置
# -----------------------------------------------------------------------------
strategies:
  # RSI策略
  rsi:
    enabled: true
    period: 14               # RSI周期
    oversold: 35            # 超卖阈值
    overbought: 65          # 超买阈值
    weight: 0.2              # 策略权重

  # MACD策略
  macd:
    enabled: true
    fast: 12                # 快线
    slow: 26                 # 慢线
    signal: 9                # 信号线
    weight: 0.2

  # 均线交叉策略
  ma_cross:
    enabled: true
    fast_period: 5           # 快线周期
    slow_period: 20          # 慢线周期
    weight: 0.2

  # 布林带策略
  bollinger:
    enabled: true
    period: 20              # 周期
    std: 2                  # 标准差倍数
    weight: 0.2

  # 组合策略
  composite:
    enabled: true
    min_strength: 70         # 最小信号强度
    require_multi: true     # 需要多策略确认
    weight: 0.2

# -----------------------------------------------------------------------------
# 信号过滤
# -----------------------------------------------------------------------------
filters:
  min_price_change: 0.02    # 最小价格变动 (2%)
  trend_confirmation: true   # 趋势确认
  multi_timeframe: false    # 多时间周期
  volume_confirm: false     # 成交量确认

# -----------------------------------------------------------------------------
# 机器学习
# -----------------------------------------------------------------------------
ml:
  enabled: true              # 启用ML预测
  model_path: ./ml/models/  # 模型路径
  min_confidence: 0.65      # 最小置信度

# -----------------------------------------------------------------------------
# Discord通知
# -----------------------------------------------------------------------------
notifications:
  discord:
    enabled: true
    channel_id: "your_channel_id"

# -----------------------------------------------------------------------------
# 仪表盘配置
# -----------------------------------------------------------------------------
dashboard:
  host: 0.0.0.0
  port: 8080
  username: admin
  password: admin

# =============================================================================
# 风险提示
# =============================================================================
# ⚠️ 合约交易风险极高，可能亏损全部资金！
# ⚠️ 请先用模拟盘(testnet)充分测试
# ⚠️ 请设置合理的止损止盈比例
# ⚠️ 不要投入超过承受能力的资金
# =============================================================================
