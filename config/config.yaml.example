# ============================================================================
# OKX Quant 示例配置（可公开提交）
# ----------------------------------------------------------------------------
# 用法建议：
# 1. 先复制：cp config/config.yaml.example config/config.yaml
# 2. 再复制：cp config/config.local.yaml.example config/config.local.yaml
# 3. 把真实 secret 只写进 config.local.yaml，或者改用环境变量
# 4. config.yaml / config.local.yaml 都不会上传到 GitHub
# 5. 默认只会自动合并项目内 config/config.local.yaml
#    ~/.crypto-quant-okx.local.yaml 已降级为兼容后门：只有显式设置
#    CRYPTO_QUANT_OKX_ENABLE_HOME_LOCAL=1 或
#    CRYPTO_QUANT_OKX_HOME_LOCAL_CONFIG=/path/to/file 才会加载
#
# 环境变量写法示例：
#   key: ${OKX_API_KEY}
#   bot_token: ${DISCORD_BOT_TOKEN:-}
# ============================================================================

api:
  # OKX API（建议放到 config.local.yaml 或环境变量）
  key: ${OKX_API_KEY:-your_okx_api_key}
  passphrase: ${OKX_API_PASSPHRASE:-your_okx_api_passphrase}
  secret: ${OKX_API_SECRET:-your_okx_api_secret}

dashboard:
  auto_refresh_seconds: 30
  enabled: true
  host: 0.0.0.0
  port: 5555
  theme: dark
  title: OKX量化交易仪表盘

database:
  path: data/trading.db
  retention:
    logs_days: 30
    signals_days: 90
    trades_days: 365
  type: sqlite

exchange:
  default_leverage: 3
  mode: testnet         # testnet=模拟盘 / real=真实盘
  name: okx
  position_mode: hedge  # hedge=双向持仓 / oneway=单向持仓；必须与 OKX 账户设置一致

governance:
  pool_switch:
    min_hold_hours: 6
    score_margin: 1.0
  rollout_executor:
    enabled: false
    mode: disabled   # disabled|dry_run|controlled；默认安全关闭，仅 skeleton：先做 plan/dispatch/apply/result 骨架，真实 live trading 参数改写仍不自动执行
    dry_run: false
    actor: system:rollout-executor
    source: rollout_executor
    reason_prefix: rollout executor skeleton apply
    allowed_action_types: [joint_observe]   # 当前可 apply 的 very-safe 动作：joint_observe/joint_queue_promote_safe/joint_stage_prepare/joint_review_schedule/joint_metadata_annotate；其余如 joint_expand_guarded/rollout_freeze 等暂只 queue/plan
    default_review_after_hours: 24
  controlled_rollout_execution:
    enabled: false
    mode: disabled   # disabled|state_apply；默认安全关闭，只允许低风险白名单动作做受控持久化，不做真实交易执行
    actor: system:controlled-rollout
    source: controlled_rollout_execution
    reason_prefix: controlled rollout state apply
    auto_promote_ready_candidates: false   # 显式安全开关；只有 true 时先会消费 auto_promotion_candidate_view，把真正 ready/very-safe/low-risk/no-blocker/no-manual-fallback 的 candidate 推进真实 stage/state
    max_executed_per_pass: 1               # 建议生产低干预先从 1 开始；0=不设上限。用作 blast-radius fence，避免单轮编排推进过多 candidate
    selection_policy: oldest_pending_first  # budget 命中时优先消费最旧 pending/review-due item，避免固定 payload 顺序长期饿死尾部 candidate
    allowed_action_types: [joint_observe]   # 支持的 very-safe 动作：joint_observe/joint_queue_promote_safe/joint_stage_prepare/joint_review_schedule/joint_metadata_annotate；默认仍只开 joint_observe
    target_state: ready
    target_workflow_state: ready
    default_review_after_hours: 24
  auto_approval_execution:
    enabled: false
    mode: disabled   # disabled|controlled；默认安全关闭，只有 controlled 才会把符合条件项推进到真实 approved/ready
    actor: system:auto-approval
    source: auto_approval_execution
    reason_prefix: controlled auto-approval execution
    max_executed_per_pass: 1   # 建议生产低干预先从 1 开始；0=不设上限。先限制上游 auto-approval blast radius，再交给后续 rollout fence 接力
    selection_policy: oldest_pending_first  # budget 命中时优先放行等待最久的 pending item，避免同一批头部 item 长期霸占名额
  recovery_execution:
    enabled: false
    mode: disabled   # disabled|dry_run|controlled；只消费 recovery queue，做 metadata-only retry/rollback/manual recovery 调度，不做真实交易执行
    actor: system:recovery-execution
    source: recovery_execution
    reason_prefix: workflow recovery execution
    execute_retry_queue: true
    execute_rollback_candidates: true
    annotate_manual_recovery: true
  adaptive_rollout_orchestration:
    enforce_production_gate: true   # 默认保守：production rollout readiness 未过时，只跑 preflight/dry-run，不落真实自动审批/自动推进
    gate_max_items: 10
  testnet_bridge_execution:
    enabled: false
    mode: disabled   # disabled|plan_only|controlled_execute；只允许 testnet minimal smoke，严禁真实盘
    actor: system:testnet-bridge
    source: testnet_bridge_execution
    symbol: null
    side: long
    execute_profile: minimal_smoke
    require_no_pending_approvals: true
    require_controlled_rollout_execution: true
    cleanup_required: true

logging:
  backup_count: 5
  file: logs/trading.log
  format: '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
  level: INFO
  max_size_mb: 10

market_filters:
  block_counter_trend: true
  block_high_volatility: true
  block_low_volatility: true
  max_volatility: 0.05
  min_volatility: 0.0045

ml:
  enabled: true
  features:
    - RSI
    - MACD
    - MACD_signal
    - MACD_hist
    - BB_upper
    - BB_lower
    - BB_position
    - MA5_ratio
    - trend_gap
    - volume_ratio
    - returns
    - returns_3d
    - returns_5d
    - volatility
    - momentum
    - atr_ratio
  min_confidence: 0.6
  model_path: ml/models
  training:
    label_horizon: 3
    min_return_threshold: 0.002

notification:
  discord:
    # presets 只保留 enabled / notify_* 等非敏感开关
    # channel_id / webhook / bot token 只放 config.local.yaml 或环境变量
    channel_id: ${DISCORD_CHANNEL_ID:-your_discord_channel_id}
    webhook_url: ${DISCORD_WEBHOOK_URL:-}
    webhook_username: OKX量化机器人
    bot_token: ${DISCORD_BOT_TOKEN:-}
    enabled: true
    notify_errors: true
    notify_signals: true
    notify_trades: true
  email:
    enabled: false
    password: ${SMTP_PASSWORD:-your_app_password}
    smtp_host: smtp.gmail.com
    smtp_port: 587
    to_address: your_email@gmail.com
    username: your_email@gmail.com
  telegram:
    bot_token: ${TELEGRAM_BOT_TOKEN:-}
    chat_id: ${TELEGRAM_CHAT_ID:-}
    enabled: false

runtime:
  interval_seconds: 300
  max_runtime_minutes: 30
  mode: interval
  schedule: 0 * * * *
  health_summary:
    enabled: true
    hour: 20   # 每日几时发一份健康汇总（24 小时制）
  approval_hygiene:
    enabled: true
    auto_cleanup_enabled: false   # 默认先 audit-only；显式开启后守护周期会把 stale pending/ready/replayed 安全标记为 expired
    stale_after_minutes: 180
    limit: 20
    approval_type: ''
    actor: system:approval-hygiene
  adaptive_rollout_orchestration:
    enabled: false   # 默认关闭；开启后 daemon 会安全执行 workflow_ready -> adaptive rollout orchestration
    use_cache: true
    notify_on_activity: true
    min_interval_seconds: 0   # 生产建议设 >0，避免每轮都重放同一套 orchestration pass；0 表示沿用旧行为
    max_items: 5
    actor: system:runtime-adaptive-rollout-orchestration

runtime_meta:
  current_preset: btc-focused

strategies:
  adx:
    enabled: true
    period: 14
    strength_weight: 20
    threshold: 25
  bollinger:
    enabled: true
    period: 20
    std_multiplier: 2
    strength_weight: 15
  composite:
    enabled: true
    min_strategy_count: 1
    min_strength: 28
  divergence:
    enabled: true
    lookback: 20
    strength_weight: 30
  ma_cross:
    enabled: true
    fast_period: 5
    slow_period: 20
    strength_weight: 25
  macd:
    enabled: true
    fast_period: 12
    signal_period: 9
    slow_period: 26
    strength_weight: 24
  pattern:
    enabled: true
    strength_weight: 20
  rsi:
    enabled: true
    overbought: 65
    oversold: 35
    period: 14
    strength_weight: 40
  volume:
    enabled: true
    strength_weight: 32
    volume_ma_period: 20
    volume_multiplier: 1.5

symbols:
  candidate_watch_list:
    - BTC/USDT
  contract_type: usdt
  margin_type: isolated
  paused_watch_list:
    - ETH/USDT
    - SOL/USDT
    - HYPE/USDT
  quote_currency: USDT
  selection_mode: focused
  watch_list:
    - XRP/USDT

# 按币种局部覆盖：只改你想灰度测试既参数，未写既项会继续沿用全局默认值
symbol_overrides:
  BTC/USDT:
    strategies:
      composite:
        min_strategy_count: 2
    market_filters:
      block_counter_trend: true
  XRP/USDT:
    strategies:
      composite:
        min_strength: 26
    market_filters:
      min_volatility: 0.0038

trading:
  cooldown_minutes: 15
  leverage: 3
  max_consecutive_losses: 3
  loss_streak_lock_enabled: true
  loss_streak_cooldown_hours: 12
  max_daily_drawdown: 0.03
  max_exposure: 0.3
  max_position_per_symbol: 0.12
  total_margin_cap_ratio: 0.30
  total_margin_soft_cap_ratio: 0.25
  symbol_margin_cap_ratio: 0.12
  base_entry_margin_ratio: 0.08
  min_entry_margin_ratio: 0.04
  max_entry_margin_ratio: 0.10
  add_position_enabled: false
  quality_scaling_enabled: false
  high_quality_multiplier: 1.15
  low_quality_multiplier: 0.75
  max_trades_per_day: 10
  min_trade_interval: 300
  position_size: 0.08
  stop_loss: 0.018
  take_profit: 0.028
  # Phase A：fresh position 未 armed 前屏蔽普通止盈/追踪退出；0 表示关闭最小持仓时间
  exit_min_hold_seconds: 0
  # 达到该浮盈（未杠杆）后提前 armed；null 表示仅靠持仓时间/默认立即 armed
  exit_arm_profit_threshold: null
  trailing_stop: 0.01
  # 盈利触发型追踪止损：盈利达到此阈值后激活追踪（0.01 = 1%）
  # 设置为 null 或删除则始终激活（旧行为）
  trailing_activation: 0.01
  # 分批止盈 / 部分平仓机制（第一止盈层）
  # 启用分批止盈
  # partial_tp_enabled: false
  # 部分止盈触发阈值（杠杆后盈利达到此比例时执行第一次部分平仓）
  # 例如 0.015 = 1.5% 盈利（3x杠杆对应约 4.5% 标的涨幅）
  # partial_tp_threshold: 0.015
  # 部分平仓比例（每次平仓的仓位占比）
  # 例如 0.5 = 每次平 50% 仓位
  # partial_tp_ratio: 0.5

  # 分层加仓（layering）
  # 建议理解：
  # - layer_ratios: 每层目标保证金占比；默认 6% / 6% / 4%
  # - layer_max_total_ratio: 本轮分仓累计上限；通常应 >= layer_ratios 总和
  # - min_add_interval_seconds: 两层之间最短等待时间
  # - max_layers_per_signal: 单一 root signal 最多允许成交几层；设 1 代表同一 signal 只开一层
  # - direction_lock_scope: symbol 更适合当前项目，避免同币并发撕裂；symbol_side 更宽松
  # - allow_same_bar_multiple_adds: 是否允许同一 bar 连续补多层，默认 false 更稳
  layering:
    layer_count: 3
    layer_ratios: [0.06, 0.06, 0.04]
    layer_max_total_ratio: 0.16
    min_add_interval_seconds: 300
    profit_only_add: false
    disallow_skip_layers: true
    signal_idempotency_enabled: true
    signal_idempotency_ttl_seconds: 600
    direction_lock_enabled: true
    direction_lock_scope: symbol
    direction_lock_release_on_flat: true
    require_position_exists: true
    allow_same_bar_multiple_adds: false
    max_layers_per_signal: 1
    strict_ratio_sum_check: false


# Adaptive regime / guarded execute（M4 Step 3 第一批）
adaptive_regime:
  enabled: false
  mode: observe_only  # observe_only / decision_only / guarded_execute / full
  guarded_execute:
    execution_profile_hints_enabled: true
    execution_profile_enforcement_enabled: true
    layering_profile_hints_enabled: true
    layering_profile_enforcement_enabled: false
    layering_plan_shape_enforcement_enabled: false
    layering_plan_shape_rollout_symbols: []
    layering_plan_shape_rollout_fraction: 0.0
    layering_plan_shape_require_guardrails_live: true
    layering_plan_shape_fail_closed: true
    layering_plan_shape_force_baseline_on_invalid: true
    risk_hints_enabled: false
    risk_enforcement_enabled: false
    conservative_only: true
    rollout_symbols: ["BTC/USDT"]
  strategy_selection:
    enabled: true
    min_selected_strategies: 1
    max_selected_strategies: 3
    base_budget_ratio: 0.9
    min_budget_ratio: 0.2
    strategy_reactivation_gate_enabled: true
    strategy_reactivation_confirm_trades: 1
    strategy_reactivation_min_win_rate: 50
    strategy_reactivation_min_avg_return_pct: 0.0
    strategy_reactivation_require_positive_return: true
    strategy_reactivation_probation_trade_limit: 2
    strategy_reactivation_probation_weight_multiplier: 0.35
    strategy_reactivation_probation_budget_cap: 0.4
    regime_slot_caps:
      default: 2
      trend: 1
      high_vol: 1
      range: 2
    regime_budget_overrides:
      default: 0.9
      trend: 0.6
      high_vol: 0.5
      range: 0.75
  defaults:
    policy_version: adaptive_policy_v1_m4_step3
  regimes:
    high_vol:
      execution_overrides:
        layer_max_total_ratio: 0.12
        max_layers_per_signal: 1
        min_add_interval_seconds: 600
        profit_only_add: true
        allow_same_bar_multiple_adds: false
        layer_ratios: [0.05, 0.04, 0.03]  # Step 3 第一批仍 hints-only，需 layering_plan_shape_enforcement_enabled=true 才 live
